DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.boomerbill.net,localhost,127.0.0.1

DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_SSL_REQUIRE=True

FRONTEND_ORIGIN=https://boomerbill.net
PUBLIC_DOMAIN=boomerbill.net
SITE_NAME=BoomerBill
PASSWORD_RESET_CONFIRM_URL=reset-password?uid={uid}&token={token}

# Email delivery
# Use "console" for local dev, "smtp" for production
EMAIL_PROVIDER=smtp
EMAIL_BACKEND=
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-with-brevo-smtp-user
EMAIL_HOST_PASSWORD=replace-with-brevo-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=BoomerBill <noreply@boomerbill.net>
